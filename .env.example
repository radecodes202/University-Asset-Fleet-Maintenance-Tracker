# ============================================================================
# FleetTrack - University Asset & Fleet Maintenance Tracker
# Environment variables template
# ============================================================================
# Copy this file to `.env` and fill in the values for your environment.
# DO NOT commit the real `.env` file to source control.
#
# Usage:
#   cp .env.example .env       (Mac/Linux)
#   copy .env.example .env     (Windows)
# ============================================================================


# ----------------------------------------------------------------------------
# Django core
# ----------------------------------------------------------------------------

# A long, random, unpredictable string. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me-with-a-long-random-string

# Set to False in production. Leave True only for local debugging.
DEBUG=True

# Comma-separated list of hostnames the app will serve.
# Add your Render/Railway URL once you deploy.
ALLOWED_HOSTS=127.0.0.1,localhost,0.0.0.0


# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
# Leave DATABASE_URL blank to use the local SQLite file (db.sqlite3) for dev.
# In production on Render/Railway, set this to the auto-provided DATABASE_URL
# from the platform's PostgreSQL service.
#
# Example local (SQLite, leave blank):
#   DATABASE_URL=
#
# Example production (PostgreSQL on Render):
#   DATABASE_URL=postgres://user:password@host:5432/dbname
DATABASE_URL=


# ----------------------------------------------------------------------------
# Cloudinary (media storage)
# ----------------------------------------------------------------------------
# Get these from https://cloudinary.com/console after creating a free account.
# REQUIRED for production — local media is wiped every time the dyno restarts.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret


# ----------------------------------------------------------------------------
# CORS (Cross-Origin Resource Sharing)
# ----------------------------------------------------------------------------
# Comma-separated list of front-end origins allowed to call the API.
# In production, add your deployed URL.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
